{
  "name": "usuarios-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Módulo Usuarios — orquestador raíz (backend + frontend)",
  "scripts": {
    "install:all": "npm install && npm --prefix server install && npm --prefix client install",
    "dev": "concurrently -k -n SERVER,CLIENT -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server start",
    "lint": "npm --prefix server run lint"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
